MONGODB_URI=mongodb://localhost:27017/tuition-platform
# Read preference for replica sets. Default: secondaryPreferred (reads from secondaries when available).
# Set MONGODB_READ_PREFERENCE=primary to disable. Requires MongoDB replica set (e.g. Atlas).
JWT_SECRET=your-super-secret-key-change-in-production
GEMINI_API_KEY=your-gemini-api-key
# OpenAI (fallback). New accounts get $5 free credits.
OPENAI_API_KEY=your-openai-api-key
# Groq - Free tier, ultra-fast. Get key: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key
# Together AI - Free models. Get key: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=your-together-api-key
# Hugging Face - Enable Groq in Inference Providers. Get token: https://huggingface.co/settings/tokens
HF_TOKEN=your-hf-token
# HF_MODEL=meta-llama/Llama-3.3-70B-Instruct:groq  # optional override
# OpenRouter - Free: ~50 req/day. Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key
# Cloudflare Workers AI - Free: 10k Neurons/day. Get: Account ID + API token.
# CLOUDFLARE_ACCOUNT_ID=your-account-id
# CLOUDFLARE_API_TOKEN=your-api-token
# HERE Maps Geocoding (for location/address autocomplete)
HERE_API_KEY=your-here-api-key
# NEXT_PUBLIC_HERE_API_KEY also supported for backwards compatibility
CRON_SECRET=your-cron-secret
PORT=3005
# CORS: allow-all (origin: true). No config needed.

# Redis (for caching and job queue; start-all.sh starts Redis locally)
REDIS_URL=redis://localhost:6379
# Job queue (BullMQ): cron jobs run in background when REDIS_URL is set

# AI Service (optional)
AI_SERVICE_URL=http://localhost:3006
AI_SERVICE_API_KEY=guruchakra-ai-secret-key
AI_MONITOR_JWT_SECRET=same-as-JWT_SECRET
# Circuit breaker: fail fast after N failures. Cooldown before retry (ms).
# AI_CIRCUIT_BREAKER_THRESHOLD=5
# AI_CIRCUIT_BREAKER_COOLDOWN_MS=30000
